# Multi-stage build for the radio-enabled backend.
# Uses pure-Go SQLite (modernc.org/sqlite), no CGO required.
FROM golang:1.26-alpine AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -ldflags='-s -w' -o /app/raga-backend .

# Runtime
FROM alpine:latest

RUN apk --no-cache add ca-certificates

WORKDIR /app
COPY --from=builder /app/raga-backend .
RUN mkdir -p /music /data

EXPOSE 3000

ENTRYPOINT ["/app/raga-backend"]
